{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Commercial-Lease",
  "description": "Commercial real estate lease agreement with legal prose sections.",
  "type": "object",
  "required": [
    "LandlordName",
    "TenantName",
    "PropertyAddress",
    "SquareFootage",
    "LeaseStartDate",
    "LeaseEndDate",
    "MonthlyRent",
    "SecurityDeposit",
    "PermittedUse",
    "Sections"
  ],
  "properties": {
    "LandlordName": {
      "type": "string",
      "description": "Full legal name of landlord or property management company"
    },
    "LandlordAddress": {
      "type": "string"
    },
    "TenantName": {
      "type": "string",
      "description": "Full legal name of tenant business"
    },
    "TenantAddress": {
      "type": "string"
    },
    "PropertyAddress": {
      "type": "string",
      "description": "Full address including suite/unit number"
    },
    "SquareFootage": {
      "type": "integer"
    },
    "LeaseStartDate": {
      "type": "string"
    },
    "LeaseEndDate": {
      "type": "string"
    },
    "MonthlyRent": {
      "type": "number"
    },
    "AnnualEscalation": {
      "type": "string",
      "description": "e.g., 3% per year"
    },
    "SecurityDeposit": {
      "type": "number"
    },
    "CAMCharges": {
      "type": "number",
      "description": "Monthly common area maintenance charges"
    },
    "PermittedUse": {
      "type": "string",
      "description": "Specific business use permitted"
    },
    "Sections": {
      "type": "array",
      "description": "Numbered lease sections, each with substantive legal prose",
      "items": {
        "type": "object",
        "required": [
          "Title",
          "Content"
        ],
        "properties": {
          "SectionNumber": {
            "type": "integer"
          },
          "Title": {
            "type": "string",
            "description": "e.g., Premises, Term, Rent, Security Deposit"
          },
          "Content": {
            "type": "string",
            "description": "1-3 paragraphs of legal prose for this section"
          }
        }
      }
    }
  }
}
