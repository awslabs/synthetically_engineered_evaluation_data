{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Invoice",
  "description": "A commercial invoice for goods or services rendered.",
  "type": "object",
  "required": [
    "header",
    "invoice_meta",
    "bill_to",
    "line_items",
    "totals"
  ],
  "properties": {
    "header": {
      "type": "object",
      "required": [
        "company_name",
        "company_address",
        "company_phone"
      ],
      "properties": {
        "company_name": {
          "type": "string"
        },
        "company_address": {
          "type": "string"
        },
        "company_phone": {
          "type": "string"
        },
        "company_email": {
          "type": "string",
          "format": "email"
        },
        "logo_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "invoice_meta": {
      "type": "object",
      "required": [
        "invoice_number",
        "invoice_date",
        "due_date"
      ],
      "properties": {
        "invoice_number": {
          "type": "string",
          "pattern": "^INV-[0-9]{4,}-[A-Z]{2,}$"
        },
        "invoice_date": {
          "type": "string",
          "format": "date"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "po_number": {
          "type": "string"
        }
      }
    },
    "bill_to": {
      "type": "object",
      "required": [
        "name",
        "address"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "company": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": [
          "description",
          "quantity",
          "unit_price",
          "amount"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "unit_price": {
            "type": "number",
            "minimum": 0
          },
          "amount": {
            "type": "number",
            "minimum": 0,
            "description": "Must equal quantity * unit_price"
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "subtotal",
        "tax_rate",
        "tax",
        "total"
      ],
      "properties": {
        "subtotal": {
          "type": "number",
          "description": "Sum of all line_items[].amount"
        },
        "tax_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Decimal tax rate, e.g. 0.0825 for 8.25%"
        },
        "tax": {
          "type": "number",
          "description": "subtotal * tax_rate"
        },
        "total": {
          "type": "number",
          "description": "subtotal + tax"
        }
      }
    },
    "footer": {
      "type": "object",
      "properties": {
        "payment_terms": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
